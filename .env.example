# =============================================================================
# AgentMkt — Lightning Agent Marketplace
#
# Copy this file to `.env` at the repo root. Every service reads from this
# single file. NEVER commit `.env`.
# =============================================================================

# --- Database --------------------------------------------------------------
# One shared Postgres 16 instance. Use Neon free tier for dev.
DATABASE_URL=postgres://user:pass@host:5432/agentmkt

# --- LLM (used by P1 + P3 — not by P2 hub, but kept here for the team) ---
NVIDIA_API_KEY=nvapi-xxxxx
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
ANTHROPIC_API_KEY=sk-ant-xxxxx
LLM_FALLBACK_TO_ANTHROPIC=false

# --- Lightning (hub) -------------------------------------------------------
# The hub talks to a Lexe sidecar binary running locally. The sidecar holds
# the wallet seed and exposes a REST API on localhost:5393 by default.
LEXE_SIDECAR_URL=http://localhost:5393
LEXE_NETWORK=mainnet
HUB_BASE_URL=http://localhost:4002

# Optional: Lexe sidecar credentials. Populated after `lexe-sidecar setup`.
# Leave blank if the sidecar binary is started manually with its own config.
LEXE_CLIENT_CREDENTIALS=

# Maximum routing fee the hub will pay (sats) when paying L402 invoices.
# Used as a hard ceiling; the hub also computes a per-invoice cap = max(2, 1%).
HUB_MAX_ROUTING_FEE_SATS=50

# Marketplace fee in basis points (500 = 5%).
HUB_FEE_BPS=500

# --- Lightning (suppliers, only Next.js demo suppliers) ------------------
MDK_ACCESS_TOKEN_SUMMARIZER=mdk_xxxxx
MDK_MNEMONIC_SUMMARIZER=word1 word2 ...
MDK_ACCESS_TOKEN_TRANSLATOR=mdk_xxxxx
MDK_MNEMONIC_TRANSLATOR=word1 word2 ...
MDK_ACCESS_TOKEN_TTS=mdk_xxxxx
MDK_MNEMONIC_TTS=word1 word2 ...

# --- Marketplace -----------------------------------------------------------
MARKETPLACE_BASE_URL=http://localhost:4003
INDEX_402_MCP_URL=https://mcp.402index.io

# --- Telegram --------------------------------------------------------------
TELEGRAM_BOT_TOKEN=xxxxx
TELEGRAM_BOT_USERNAME=AgentMktBot
# Hub calls this URL to push human-task briefs.
TG_BOT_URL=http://localhost:4004

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4001

# --- Service ports (local dev) --------------------------------------------
PORT_WEB=3000
PORT_ORCHESTRATOR=4001
PORT_HUB=4002
PORT_MARKETPLACE=4003
PORT_TG_BOT=4004
PORT_SUPPLIER_SUMMARIZER=5001
PORT_SUPPLIER_TRANSLATOR=5002
PORT_SUPPLIER_TTS=5003

# --- Demo seeding ----------------------------------------------------------
DEMO_BUYER_USER_ID=user_demo_buyer
DEMO_HUMAN_WORKER_TG_CHAT_ID=000000000

# --- Hub-only knobs (P2) ---------------------------------------------------
# When `true`, the hub uses a console-log mock instead of calling the real
# tg-bot. Useful while P4 is still scaffolding.
USE_MOCKS=false

# Default expiry (seconds) for topup invoices.
HUB_DEFAULT_INVOICE_EXPIRY_SECS=3600

# Pretty-print pino logs in dev. Set to "false" in production.
HUB_LOG_PRETTY=true
